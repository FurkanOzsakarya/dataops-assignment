# ----------------------------------------------------------------------------
# Copy this file to `.env` and adjust values before running `docker compose up`.
# ----------------------------------------------------------------------------

# Your machine's host UID so Airflow can write logs (Linux/macOS: run `id -u`)
AIRFLOW_UID=50000

# ---- GitHub repo that git-sync will pull (CI). Use the HTTPS clone URL. -----
# Example: https://github.com/<user>/dataops-assignment.git
GITSYNC_REPO=https://github.com/CHANGE_ME/dataops-assignment.git
GITSYNC_REF=main
# For a PRIVATE repo also set a token (Personal Access Token, repo scope):
GITSYNC_USERNAME=
GITSYNC_PASSWORD=

# ---- RustFS (S3-compatible object storage) ----
RUSTFS_ACCESS_KEY=rustfsadmin
RUSTFS_SECRET_KEY=rustfsadmin
BRONZE_BUCKET=dataops-bronze
RAW_OBJECT_KEY=raw/dirty_store_transactions.csv

# ---- PostgreSQL data sink (traindb) ----
POSTGRES_DB=traindb
POSTGRES_USER=train
POSTGRES_PASSWORD=Ankara06
POSTGRES_SCHEMA=public
TARGET_TABLE=clean_data_transactions

# ---- spark_client SSH credentials (used by Airflow SSHOperator) ----
SPARK_SSH_USER=train
SPARK_SSH_PASSWORD=Ankara06
